# HouseTab environment variables — copy to `.env.local` for local dev, set in Vercel for prod.
# NEVER commit real secrets. This file documents the required keys only.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and keys from the Supabase dashboard (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable / anon key — safe to expose to the browser (RLS enforces access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Service-role (secret) key — SERVER-SIDE ONLY. Used by the webhook/cron routes to
# bypass RLS. Never expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── Telegram Bot API ──────────────────────────────────────────────────────────
# Token from @BotFather (/newbot). Server-side only.
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token
# Random secret sent as the X-Telegram-Bot-Api-Secret-Token header on setWebhook;
# the webhook route rejects any request whose header doesn't match. Generate with
# e.g. `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET=generate-a-long-random-string

# ─── App ───────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used to register the Telegram webhook URL).
# Locally this is http://localhost:3000; in prod it's the Vercel production URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret protecting the /api/cron/reminders route (Vercel Cron sends it as a
# Bearer token). Generate with `openssl rand -hex 32`.
CRON_SECRET=generate-a-long-random-string
